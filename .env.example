# ============================================================
# KOPIRAJ TO DATOTEKO KOT .env.local (lokalno) ALI V VERCEL
# ============================================================

# --- CLERK (prijava poročencev) ---
# Dashboard: https://dashboard.clerk.com → API Keys
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_VAS_KLJUC
CLERK_SECRET_KEY=sk_test_VAS_KLJUC

# Poti za prijavo (obvezno enako na Vercelu in lokalno)
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/prijava
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/registracija
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL=/ustvari
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL=/ustvari

# --- STRIPE (plačila) ---
# Dashboard: https://dashboard.stripe.com → Developers → API keys
STRIPE_SECRET_KEY=sk_test_VAS_KLJUC
STRIPE_WEBHOOK_SECRET=whsec_VAS_KLJUC

# --- NEOSERV MySQL (baza) ---
# Možnost A: ena povezava (priporočeno)
DATABASE_URL=mysql://UPORABNIK:GESLO@HOST.neoserv.si:3306/IME_BAZE

# Možnost B: posamezna polja (če raje)
# DATABASE_HOST=HOST.neoserv.si
# DATABASE_PORT=3306
# DATABASE_USER=UPORABNIK
# DATABASE_PASSWORD=GESLO
# DATABASE_NAME=IME_BAZE

# --- URL strani ---
# Lokalno:
# NEXT_PUBLIC_BASE_URL=http://localhost:3000
# Produkcija:
NEXT_PUBLIC_BASE_URL=https://porocni-organizator.visionone.si
